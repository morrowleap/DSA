{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Delete Java Class Files",
            "type": "shell",
            "command": "find . -name '*.class' -delete",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Git Update",
            "type": "shell",
            "command": "git add . && git commit -m \"update\" && git push origin main",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ]
}